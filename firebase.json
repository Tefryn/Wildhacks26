{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "scripts/firebase-functions-predeploy.cmd"
      ]
    }
  ],
  "database": {
    "rules": "database.rules.json"
  }
}
