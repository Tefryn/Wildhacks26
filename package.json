{
  "name": "wildhacks26",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build": "npm run build -w client",
    "fetch:steam-top-games": "node scripts/fetch-steam-top-games.mjs",
    "filter:filter-tags": "node scripts/filter-tags.mjs",
    "build:recommendation-table": "node scripts/build-recommendation-table.mjs",
    "ingest:firestore": "node scripts/ingest-to-firestore.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "dependencies": {
    "firebase-admin": "^13.8.0"
  }
}
